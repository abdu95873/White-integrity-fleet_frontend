# Frontend dev server port
VITE_PORT=5173

# Backend URL used by Vite dev proxy (server-side only, not exposed to browser)
VITE_BACKEND_URL=http://localhost:5000

# API base URL used by the browser
# Dev: keep /api so Vite proxy forwards to backend
# Production: set full backend URL, e.g. https://api.yourdomain.com/api
VITE_API_URL=/api
