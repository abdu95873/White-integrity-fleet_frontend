# Frontend dev server port
VITE_PORT=5173

# Backend URL used by Vite dev proxy (server-side only)
VITE_BACKEND_URL=http://localhost:5000

# API base URL used by the browser
# Local dev + production: keep /api (Vite dev proxy / Vercel rewrite in vercel.json)
VITE_API_URL=/api

# Optional: local frontend with deployed backend (direct cross-origin, no proxy)
# VITE_BACKEND_URL=https://white-integrity-fleet-backend-rouge.vercel.app
# VITE_API_URL=https://white-integrity-fleet-backend-rouge.vercel.app/api

