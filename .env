# Local development
VITE_PORT=5173

# Vite dev proxy target. Use localhost when running backend locally.
VITE_BACKEND_URL=http://localhost:5000

# Browser API base. Keep /api for local dev so Vite proxy forwards requests.
VITE_API_URL=/api

# To test against deployed backend locally, uncomment both lines below and comment the two active URL lines above.
# VITE_BACKEND_URL=https://white-integrity-fleet-backend-rouge.vercel.app
# VITE_API_URL=https://white-integrity-fleet-backend-rouge.vercel.app/api